{
  "name": "ai-sdk-local-fetch",
  "version": "0.1.0",
  "description": "Use Vercel AI SDK streamText directly on the client — no server required",
  "keywords": [
    "ai",
    "ai-sdk",
    "ai-elements",
    "ssg",
    "client-side",
    "local",
    "llm",
    "vercel",
    "fetch"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "ai": "^6.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
